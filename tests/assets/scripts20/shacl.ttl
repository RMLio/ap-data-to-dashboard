@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org#> .

# NodeShape without rdfs:label - should use "Person" from NodeShape IRI (before Shape)
<http://example.org#PersonShape> a shacl:NodeShape;
  shacl:targetClass ex:Human;
  shacl:property [
    a shacl:PropertyShape;
    # PropertyShape without rdfs:label but with shacl:name - should use shacl:name
    shacl:name "ageFromName";
    shacl:path ex:age;
    shacl:datatype xsd:integer
  ], [
    a shacl:PropertyShape;
    # PropertyShape without rdfs:label and shacl:name - should use "email" from path
    shacl:path ex:email;
    shacl:datatype xsd:string
  ] .
